---
import Base from '../layouts/Base.astro';
---

<Base
  title="connect — luqmaan.dev"
  description="Find Luqmaan Ahmed across the internet — LinkedIn, UpScrolled, Twitter/X."
>
  <main class="page">
    <header class="site-header">
      <a href="/" class="site-logo">luqmaan.dev</a>
      <a href="/connect" class="nav-link active">connect →</a>
    </header>

    <p class="page-subtitle">Find me across the internet.</p>

    <ul class="connect-list">
      <li class="connect-item">
        <div class="connect-label">
          <div class="connect-name">LinkedIn</div>
          <div class="connect-desc">Professional background, work, and writing I co-publish.</div>
        </div>
        <a
          href="https://linkedin.com/in/luqmaan-ahmed"
          class="connect-link"
          target="_blank"
          rel="noopener noreferrer"
        >
          linkedin.com/in/luqmaan-ahmed →
        </a>
      </li>

      <li class="connect-item">
        <div class="connect-label">
          <div class="connect-name">UpScrolled</div>
          <div class="connect-desc">Day-to-day thoughts, from anything I find interesting.</div>
        </div>
        <a
          href="https://upscrolled.com/@luqs1"
          class="connect-link"
          target="_blank"
          rel="noopener noreferrer"
        >
          upscrolled.com/@luqs1 →
        </a>
      </li>

      <li class="connect-item">
        <div class="connect-label">
          <div class="connect-name">Twitter / X</div>
          <div class="connect-desc">still where tech happens (unfortunately)</div>
        </div>
        <a
          href="https://x.com/_luqy"
          class="connect-link"
          target="_blank"
          rel="noopener noreferrer"
        >
          x.com/_luqy →
        </a>
      </li>
    </ul>
  </main>
</Base>
